# BookfFinder backend - copy this to .env and fill in the values
# NEVER commit .env - only commit this .env.example file

PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bookfinder

# Goolge Books API (get from console.cloud.goole.com)
GOOGLE_BOOKS_API_KEY=your_key_here

#AWS (Thase 5 - leave blank for now)
AWS_REGION=af-south-1
AWS_S3_BUCKET=
